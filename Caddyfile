# TriageAI — Production Caddyfile
# Auto-HTTPS via Let's Encrypt

{$DOMAIN:triageai.ca} {
	# Backend API + WebSocket — all /v1/* and /health go to the API container.
	# Caddy v2 automatically detects and proxies WebSocket upgrade requests.
	handle /v1/* {
		reverse_proxy api:8000
	}
	handle /health {
		reverse_proxy api:8000
	}
	handle /docs {
		reverse_proxy api:8000
	}

	# Frontend SPA — catch-all (everything else goes to frontend)
	handle {
		reverse_proxy frontend:3000
	}

	# Security headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Gzip
	encode gzip

	# Logs
	log {
		output file /var/log/caddy/access.log
		format json
	}
}
