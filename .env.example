# TriageAI — Environment Variables
# Copy this file to .env and fill in real values before running locally.
# NEVER commit .env to version control.

# ─── Twilio ───────────────────────────────────────────────────────────────────
# Account SID from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth token from https://console.twilio.com (treat like a password)
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio phone number in E.164 format (purchased from Twilio)
TWILIO_PHONE_NUMBER=+16475550000

# Nurse line phone number — warm transfers go here on CTAS L1
ESCALATION_PHONE_NUMBER=+16135550001

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# API key from https://platform.openai.com/api-keys
# Set a $50/month billing alert before using in production
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase connection string (Transaction Pooler recommended for serverless)
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://triageai:triageai_dev@localhost:5432/triageai

# ─── Security ─────────────────────────────────────────────────────────────────
# 64-character random string — generate with: openssl rand -hex 32
SECRET_KEY=change_me_to_a_64_character_random_string_before_deploying

# Runtime environment: development | staging | production
ENVIRONMENT=development

# ─── Sentry ───────────────────────────────────────────────────────────────────
# Error tracking DSN — leave empty to disable
SENTRY_DSN=

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Multilingual support (V2)
FF_MULTILINGUAL=false

# Admin dashboard (V2)
FF_ADMIN_DASHBOARD=false

# Analytics (V2)
FF_ANALYTICS=false

# Crisis override — NEVER set to false
FF_CRISIS_OVERRIDE=true
