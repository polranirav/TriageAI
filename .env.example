# TriageAI — Environment Variables
# Copy this file to .env and fill in real values before running locally.
# NEVER commit .env to version control.

# ─── Twilio ───────────────────────────────────────────────────────────────────
# Account SID from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth token from https://console.twilio.com (treat like a password)
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio phone number in E.164 format (purchased from Twilio)
TWILIO_PHONE_NUMBER=+16475550000

# Nurse line phone number — warm transfers go here on CTAS L1
ESCALATION_PHONE_NUMBER=+16135550001

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# API key from https://platform.openai.com/api-keys
# Set a $50/month billing alert before using in production
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Database ─────────────────────────────────────────────────────────────────
# Production: docker-compose.prod.yml overrides this to use the local containerised DB.
# Dev (no Docker): point to your local Postgres or a Supabase Session Pooler URL.
# NOTE: Supabase direct connections (db.xxxx.supabase.co:5432) are IPv6-only on newer
#       infrastructure and will fail inside Docker. Use the Session Pooler URL instead:
#       postgresql+asyncpg://postgres.[ref]:[password]@aws-0-ca-central-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://triageai:triageai_dev@localhost:5432/triageai

# ─── Local PostgreSQL container (production Docker) ───────────────────────────
# Used by docker-compose.prod.yml to configure the bundled Postgres service.
# docker-compose.prod.yml builds DATABASE_URL from these values automatically.
POSTGRES_USER=triageai
POSTGRES_PASSWORD=change_me_to_a_strong_db_password
POSTGRES_DB=triageai

# ─── Application ──────────────────────────────────────────────────────────────
# Public base URL — used to build wss:// URLs in TwiML responses
# Dev: use your ngrok HTTPS URL (e.g. https://abc123.ngrok.io)
# Prod: https://api.triageai.ca
BASE_URL=http://localhost:8000

# ─── Security ─────────────────────────────────────────────────────────────────
# 64-character random string — generate with: openssl rand -hex 32
SECRET_KEY=change_me_to_a_64_character_random_string_before_deploying

# Runtime environment: development | staging | production
ENVIRONMENT=development

# ─── Admin Dashboard Credentials ──────────────────────────────────────────────
# Used to log into the admin dashboard at /login
ADMIN_EMAIL=admin@triageai.ca
ADMIN_PASSWORD=change_me_to_a_strong_password

# ─── Sentry ───────────────────────────────────────────────────────────────────
# Error tracking DSN — leave empty to disable (backend)
SENTRY_DSN=

# Frontend Sentry DSN (VITE_ prefix exposes to browser bundle)
VITE_SENTRY_DSN=

# Frontend runtime environment (development | staging | production)
VITE_ENVIRONMENT=development

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Multilingual support (V2)
FF_MULTILINGUAL=false

# Admin dashboard (V2)
FF_ADMIN_DASHBOARD=false

# Analytics (V2)
FF_ANALYTICS=false

# Crisis override — NEVER set to false
FF_CRISIS_OVERRIDE=true
